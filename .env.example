NGINX_PORT=8080
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672
MQTT_PORT=1883
POSTGRES_EVENTS_PORT=5433
POSTGRES_ADMIN_PORT=5434
POSTGRES_DOWNTIME_PORT=5435
REDIS_PORT=6379
NODERED_PORT=1880
FRONTEND_PORT=5173

POSTGRES_EVENTS_USER=events
POSTGRES_EVENTS_PASSWORD=events
POSTGRES_EVENTS_DB=events

POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=admin
POSTGRES_ADMIN_DB=admin

POSTGRES_DOWNTIME_USER=downtime
POSTGRES_DOWNTIME_PASSWORD=downtime
POSTGRES_DOWNTIME_DB=downtime

RABBIT_URL=amqp://guest:guest@rabbitmq:5672/
REDIS_URL=redis://redis_auth:6379/0

AUTH_JWT_SECRET=devsecret
AUTH_JWT_ISSUER=asmon
AUTH_JWT_AUDIENCE=asmon
AUTH_DISABLED=true
ENABLE_OFFLINE_CHECK=false

EVENTS_API_DATABASE_URL=postgresql+psycopg2://events:events@postgres_events:5432/events
EVENT_WRITER_DATABASE_URL=postgresql+psycopg2://events:events@postgres_events:5432/events

DOWNTIME_EVENTS_DB_URL=postgresql+psycopg2://events:events@postgres_events:5432/events
DOWNTIME_ADMIN_DB_URL=postgresql+psycopg2://admin:admin@postgres_admin:5432/admin
DOWNTIME_DOWNTIME_DB_URL=postgresql+psycopg2://downtime:downtime@postgres_downtime:5432/downtime

REPORTS_EVENTS_DB_URL=postgresql+psycopg2://events:events@postgres_events:5432/events
REPORTS_ADMIN_DB_URL=postgresql+psycopg2://admin:admin@postgres_admin:5432/admin
REPORTS_DOWNTIME_DB_URL=postgresql+psycopg2://downtime:downtime@postgres_downtime:5432/downtime

DJANGO_SECRET_KEY=devsecret
DJANGO_DEBUG=true
ADMIN_DATABASE_URL=postgres://admin:admin@postgres_admin:5432/admin
ADMIN_EVENTS_DB_URL=postgres://events:events@postgres_events:5432/events
ADMIN_DOWNTIME_DB_URL=postgres://downtime:downtime@postgres_downtime:5432/downtime

SIMULATOR_ADMIN_API_URL=http://nginx/api/admin/equipment/
SIMULATOR_MQTT_HOST=mosquitto
SIMULATOR_MQTT_PORT=1883
SIMULATOR_POLL_INTERVAL_SEC=2
SIMULATOR_REQUEST_TIMEOUT_SEC=5

VITE_API_PROXY_TARGET=http://nginx:80
